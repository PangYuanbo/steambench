    "agent:run-session": "node scripts/agent-run-session.mjs",
    "runtime:action-spaces": "node scripts/runtime-action-spaces.mjs",
    "agent:trace-audit": "node scripts/agent-trace-audit.mjs",
    "agent:trace-ops": "node scripts/agent-trace-ops.mjs",
    "steam:ingest": "node scripts/steam-ingest.mjs",
    "steam:metrics": "node scripts/steam-metric-proposals.mjs",
    "steam:stats": "node scripts/steam-stat-proposals.mjs",
    "steam:leaderboards": "node scripts/steam-leaderboard-proposals.mjs",
    "steam:source-queue": "node scripts/steam-source-queue.mjs",
    "steam:ops": "node scripts/steam-task-source-ops.mjs",
