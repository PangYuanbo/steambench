{
  "name": "steambench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "audit:contracts": "node scripts/audit-task-contracts.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:task": "python3 benchmark_tasks/achievement_capture/smoke_eval.py",
    "blind:task": "python3 benchmark_tasks/achievement_capture/blind_eval.py",
    "certificate:verify": "node scripts/result-certificate-verify.mjs",
    "certificate:index": "node scripts/result-certificate-index.mjs",
    "public:catalog": "node scripts/public-catalog.mjs",
    "public:standings": "node scripts/public-standings.mjs",
    "public:hub": "node scripts/public-hub.mjs",
    "public:quickstart": "node scripts/public-quickstart.mjs",
    "public:event-entry": "node scripts/public-event-entry.mjs",
    "public:intake": "node scripts/public-steam-intake.mjs",
    "public:agent": "node scripts/public-agent.mjs",
    "public:action-space": "node scripts/public-action-space.mjs",
    "public:bridge-handoff": "node scripts/public-bridge-handoff.mjs",
    "public:race-entry": "node scripts/public-race-entry.mjs",
    "public:export": "node scripts/public-benchmark-export.mjs",
    "public:runner": "node scripts/public-runner.mjs",
    "public:human": "node scripts/public-human.mjs",
    "public:match": "node scripts/public-match.mjs",
    "public:watch": "node scripts/public-watch.mjs",
    "public:submit": "node scripts/public-submit.mjs",
    "worker:local": "node scripts/runtime-worker.mjs",
    "platform:ops": "node scripts/platform-ops.mjs",
    "benchmark:blueprint-ops": "node scripts/benchmark-blueprint-ops.mjs",
    "task:review-ops": "node scripts/task-review-ops.mjs",
    "bridge:control": "node scripts/control-bridge-runner.mjs",
    "bridge:ops": "node scripts/control-bridge-ops.mjs",
    "broadcast:ops": "node scripts/broadcast-ops.mjs",
    "scoreboard:ops": "node scripts/scoreboard-ops.mjs",
    "challenge:ops": "node scripts/challenge-ops.mjs",
